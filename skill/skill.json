{
  "name": "voice-typer",
  "version": "1.0.0",
  "description": "轻量级语音输入工具 - 按住快捷键说话，松开自动打字",
  "author": "robin0liu0",
  "license": "MIT",
  "keywords": ["voice", "speech", "typing", "asr", "dictation", "语音输入"],
  "commands": {
    "voice-typer": {
      "description": "启动语音输入工具",
      "script": "scripts/voice_typer.py"
    }
  },
  "triggers": [
    "语音输入",
    "voice typer",
    "启动语音",
    "开始录音",
    "语音打字"
  ],
  "platforms": ["windows", "macos", "linux"],
  "requirements": {
    "python": ">=3.8",
    "npm": [["@marswave/coli", "latest"]]
  }
}
